PORT=5055

# Public URL for open/click tracking (use your tunnel or prod URL for real recipients)
# TRACKING_BASE_URL=https://your-host.example.com

# Web app origin (optional; for docs / CORS awareness)
APP_URL=http://localhost:5174

# Mail: DRY_RUN unset or true = no SMTP (safe default)
DRY_RUN=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FlowPing <you@gmail.com>"

# Optional follow-up worker (POST /api/sends/followups/run)
# FOLLOWUP_AFTER_OPEN_HOURS=24
# FOLLOWUP_SUBJECT=Quick follow-up
# FOLLOWUP_BODY_TEXT=Following up on my last note…
